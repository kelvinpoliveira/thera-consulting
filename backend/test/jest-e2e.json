{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testMatch": ["<rootDir>/**/*.e2e-spec.ts"],
  "testEnvironment": "node",
  "extensionsToTreatAsEsm": [".ts"],
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", {
      "useESM": true
    }]
  },
  "moduleNameMapper": {
    "generated/prisma/client\\.js$": "<rootDir>/../src/__mocks__/prisma-client.mock",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}
